  /api/AIKnowledge/all/{botId}:
    get:
      tags: ["RAG Knowledge Indexing"]
      summary: List Knowledge Units
      description: |
        Retrieve all knowledge units for a specific bot with optional search filtering.
        
        **Use Cases:**
        - List all indexed documents
        - Search knowledge by title
        - Manage knowledge inventory
        - Audit indexed content

        Note: Example requests/responses shown here are illustrative. When using the live "Try it" tool, you may see two responses: an HTTP status preview and the API's JSON body.
      operationId: getAllKnowledge
      parameters:
        - in: path
          name: botId
          required: true
          schema:
            type: string
          description: Bot ID to retrieve knowledge for
          example: "12345"
        - in: query
          name: searchTitle
          required: false
          schema:
            type: string
          description: Optional search filter for knowledge titles
          example: "API Documentation"
      responses:
        '200':
          description: List of knowledge entries
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/StandardResponse'

  /api/AIKnowledge/byId/{knowledgeId}:
    get:
      tags: ["RAG Knowledge Indexing"]
      summary: Get Knowledge Unit by ID
      description: |
        Retrieve detailed information about a specific knowledge unit by its unique identifier.
        
        **Returns:**
        - Knowledge metadata
        - Source information
        - Indexing status
        - File details

        Note: Example requests/responses shown here are illustrative. When using the live "Try it" tool, you may see two responses: an HTTP status preview and the API's JSON body.
      operationId: getKnowledgeById
      parameters:
        - in: path
          name: knowledgeId
          required: true
          schema:
            type: string
          description: Unique identifier of the knowledge entry
          example: "1092"
      responses:
        '200':
          description: Knowledge entry details
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/StandardResponse'

  /api/AIKnowledge/{botId}/{knowledgeId}:
    put:
      tags: ["RAG Knowledge Indexing"]
      summary: Update Knowledge Unit
      description: |
        Update an existing knowledge unit's metadata or replace associated files.
        
        **Update Options:**
        - **Metadata Only**: Update title and description
        - **Replace Content**: Update source files or URLs
        - **Complete Replacement**: Change both metadata and content
        
        **Note:** Updating content triggers re-indexing of the knowledge unit.

        Note: Example requests/responses shown here are illustrative. When using the live "Try it" tool, you may see two responses: an HTTP status preview and the API's JSON body.
      operationId: updateKnowledge
      parameters:
        - in: path
          name: botId
          required: true
          schema:
            type: string
          description: Bot ID
          example: "12345"
        - in: path
          name: knowledgeId
          required: true
          schema:
            type: string
          description: Knowledge entry ID to update
          example: "1092"
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/AIKnowledgeUpdateRequest'
            examples:
              metadataUpdate:
                summary: Update metadata only
                description: Update title and description without changing content
                value:
                  id: 1092
                  title: "Updated API Documentation"
                  description: "Updated description for API docs"
                  KnowledgeSource: 1
              replaceFile:
                summary: Replace file content
                description: Update with new file while preserving metadata
                value:
                  id: 1092
                  title: "Updated Document"
                  description: "Document with new content"
                  KnowledgeSource: 0
                  AIKnowledgeSources:
                    - content: "{\"FileUrl\":\"https://cdn.example.com/new.docx\",\"FileName\":\"new.docx\",\"FilePath\":\"PlatformAttachments/LIVE/12345/new.docx\",\"FileSize\":15000}"
                      id: 1092
      responses:
        '200':
          description: Knowledge entry updated successfully
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/StandardResponse'
    delete:
      tags: ["RAG Knowledge Indexing"]
      summary: Delete Knowledge Unit
      description: |
        Remove a knowledge unit from your bot's knowledge base.
        
        **Warning:** This action is irreversible and will:
        - Remove the knowledge unit permanently
        - Delete associated indexed content
        - Make the content unavailable for RAG queries
        - Not affect the original source files or URLs

        Note: Example requests/responses shown here are illustrative. When using the live "Try it" tool, you may see two responses: an HTTP status preview and the API's JSON body.
      operationId: deleteKnowledge
      parameters:
        - in: path
          name: botId
          required: true
          schema:
            type: string
          description: Bot ID
          example: "12345"
        - in: path
          name: knowledgeId
          required: true
          schema:
            type: string
          description: Knowledge entry ID to delete
          example: "1092"
      responses:
        '200':
          description: Knowledge entry deleted successfully
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/StandardResponse'

  /api/v2/AQL/SpeechToText:
    post:
      tags: ["Speech to Text"]
      summary: Convert Speech to Text
      description: |
        Convert audio files to text with superior Arabic dialect recognition and support for multiple languages.
        
        **Supported Audio Formats:**
        - WAV (recommended for best quality)
        - MP3 (widely supported)
        - MP4 (audio track extraction)
        - Other common audio formats
        
        **Arabic Excellence:**
        - Industry-leading Arabic dialect recognition
        - Support for Egyptian, Gulf, Levantine, and Maghrebi variations
        - Colloquial expression handling
        - Regional pronunciation accuracy
        
        **Consumption:** Based on audio duration in seconds

        Note: Example requests/responses shown here are illustrative. When using the live "Try it" tool, you may see two responses: an HTTP status preview and the API's JSON body.
      operationId: speechToTextStandard
      requestBody:
        required: true
        content:
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/STTStandardForm'
            examples:
              arabicAudio:
                summary: Arabic audio transcription
                description: Transcribe Arabic speech to text
                value:
                  SessionId: "test-session-123"
                  SetDefaultSampleRate: "true"
                  TargetLanguage: "ar-eg"
                  MaxRecordLengthInSeconds: "180"
      responses:
        '200':
          description: Transcription successful
          content:
            application/json:
              schema:
                type: object
                properties:
                  StatusCode:
                    type: integer
                    example: 200
                  Response:
                    type: string
                    description: Transcribed text from audio
                    example: "مرحباً، كيف حالك اليوم؟ أتمنى أن تكون بخير."
                  Consumption:
                    type: string
                    description: Audio duration consumed
                    example: "15/1000"

  /api/v1/AQL/Stream/SpeechToText:
    post:
      tags: ["Speech to Text"]
      summary: Stream Text
      description: |
        Real-time speech to text conversion with streaming output for live processing applications.
        
        **Key Features:**
        - Real-time transcription
        - Progressive text output
        - Live audio processing
        - Streaming partial results
        
        **Use Cases:**
        - Live transcription services
        - Real-time voice assistants
        - Meeting transcription
        - Voice note processing

        Note: Example requests/responses shown here are illustrative. When using the live "Try it" tool, you may see two responses: an HTTP status preview and the API's streaming output.
      operationId: speechToTextStreaming
      requestBody:
        required: true
        content:
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/STTStreamForm'
      responses:
        '200':
          description: Streaming transcription with progressive results
          content:
            text/event-stream:
              schema:
                type: string
                description: Server-sent events with transcription progress
              examples:
                streamingTranscription:
                  summary: Example streaming transcription
                  value: |
                    data: {"partial": "أهلا"}
                    
                    data: {"partial": "أهلا وسهلا"}
                    
                    data: {"partial": "أهلا وسهلا بكم"}
                    
                    data: {"final": "أهلا وسهلا بكم في تطبيقات الذكاء الاصطناعي من وايد بوت"}
                    
                    data: {"status": "complete", "duration": 8.5, "consumption": "8/1000"}

  /api/v2/AQL/TextToSpeech:
    post:
      tags: ["Text to Speech"]
      summary: Convert Text to Speech
      description: |
        Convert text to high-quality speech with natural Arabic voices and multiple language support.
        
        **Arabic Excellence:**
        - Natural pronunciation for Arabic dialects
        - Regional voice variations
        - Cultural context understanding
        - Proper Arabic phonetics
        
        **Available Speakers:**
        - **Arabic Male**: 
          - **Hesham** - **HIGHLY RECOMMENDED** for MSA/Egyptian
          - **Rawy** - **HIGHLY RECOMMENDED** for Saudi
          - Other: Mohamed, Adel, Hytham
        - **Arabic Female**: Hala (Saudi), Lina, Mona, Alice, Esraa
        - **English**: Marcos Rudaski, Claribel Dervla
        
        **Consumption:** Based on character count in input text

        Note: Example requests/responses shown here are illustrative. When using the live "Try it" tool, you may see two responses: an HTTP status preview and the API's JSON body.
      operationId: textToSpeechStandard
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TTSStandardRequest'
            examples:
              arabicText:
                summary: Arabic text to speech
                description: Convert Arabic text to natural speech
                value:
                  TextMessage: "مرحباً بكم في منصة وايد بوت للذكاء الاصطناعي"
                  LanguageCode: "ar-sa"
                  speaker: "Rawy"
                  temperature: 0.5
                  output_sr: 24000
                  session_id: "tts-session-001"
              englishText:
                summary: English text to speech
                description: Convert English text to speech
                value:
                  TextMessage: "Welcome to Widebot AI platform"
                  LanguageCode: "eng"
                  speaker: "Marcos Rudaski"
                  temperature: 0.7
                  output_sr: 24000
                  session_id: "tts-session-002"
      responses:
        '200':
          description: Text to speech conversion successful
          content:
            application/json:
              schema:
                type: object
                properties:
                  StatusCode:
                    type: integer
                    example: 200
                  Response:
                    type: object
                    properties:
                      status:
                        type: string
                        example: "success"
                      audio_url:
                        type: string
                        format: uri
                        description: URL to download the generated audio file
                        example: "https://cdn.widebot.net/tmp/tts/abc123xyz/output.mp3"
                      duration_ms:
                        type: integer
                        description: Audio duration in milliseconds
                        example: 1850
                      characters:
                        type: integer
                        description: Number of characters processed
                        example: 18
                      language:
                        type: string
                        description: Language used for generation
                        example: "ar-sa"
                      speaker:
                        type: string
                        description: Voice used for generation
                        example: "Rawy"
                      output_sr:
                        type: integer
                        description: Output sample rate
                        example: 24000
                      session_id:
                        type: string
                        description: Session identifier
                        example: "tts-session-001"
                  Consumption:
                    type: string
                    description: Character usage tracking
                    example: "18/15000"

  /api/v1/AQL/Stream/TextToSpeech:
    post:
      tags: ["Text to Speech"]
      summary: Stream Speech
      description: |
        Real-time text to speech conversion with audio streaming for immediate playback.
        
        **Key Features:**
        - Real-time audio generation
        - Progressive audio chunks
        - Lower latency for long texts
        - Streaming audio playback
        
        **Use Cases:**
        - Live voice assistants
        - Real-time narration
        - Interactive voice applications
        - Immediate audio feedback
        
        **Audio Format:** MP3 chunks delivered via server-sent events

        Note: Example requests/responses shown here are illustrative. When using the live "Try it" tool, you may see two responses: an HTTP status preview and the API's streaming output.
      operationId: textToSpeechStreaming
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TTSStreamRequest'
            examples:
              streamingArabic:
                summary: Streaming Arabic TTS
                description: Real-time Arabic text to speech conversion
                value:
                  TextMessage: "مرحباً! هذا مثال على التحويل الصوتي المباشر للنص العربي"
                  LanguageCode: "ar"
                  Speaker: "Hesham"
                  Temperature: 0.8
                  OutputSampleRate: 24000
                  StreamChunkSize: 300
      responses:
        '200':
          description: Streaming audio generation with progressive chunks
          content:
            text/event-stream:
              schema:
                type: string
                description: Server-sent events with audio chunks
              examples:
                streamingAudio:
                  summary: Example streaming audio response
                  value: |
                    data: {"chunk_id": 1, "audio_data": "UklGRl4AAABXQVZFZm10...", "chunk_size": 1024}
                    
                    data: {"chunk_id": 2, "audio_data": "VFJBVEVZRjQAAABXQVZF...", "chunk_size": 1024}
                    
                    data: {"chunk_id": 3, "audio_data": "ZGF0YQQ=", "chunk_size": 512}
                    
                    data: {"status": "complete", "total_chunks": 3, "total_duration": 4.2, "consumption": "58/15000"}