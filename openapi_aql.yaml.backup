              schema:
                $ref: '#/components/schemas/StandardResponse'


  /api/v1/RAG/Answer:
    post:
      tags: ["RAG Answer Generation"]
      summary: Answer Question
      description: |
        Answer questions using Retrieval-Augmented Generation from your indexed documents with source citations.
        
        **Requirements:**
        - Documents must be pre-indexed via AI Knowledge Feature
        - Specify IndexNames to search specific document collections
        
        **Key Features:**
        - Semantic document retrieval
        - Source-backed answers
        - Relevance scoring
        - Multi-document synthesis

        Note: Example requests/responses shown here are illustrative. When using the live "Try it" tool, you may see two responses: an HTTP status preview from the client and the API's JSON body (StandardResponse envelope).
      operationId: ragAnswerStandard
      requestBody:
        required: true
        content:
          application/json:
            schema: 
              $ref: '#/components/schemas/RAGAnswerRequest'
            examples:
              basicQuery:
                summary: Basic RAG query
                description: Simple question with document index specification
                value:
                  Question: "ما هو الاسم الكامل لمحمد صلاح؟"
                  IndexNames: ["Mohamed Salah"]
                  Limit: 10
                  Temperature: 0.1
                  MaxOutputTokens: 1024
                  IsStream: false
      responses:
        '200':
          description: RAG answer with retrieved documents and sources
          content:
            application/json:
              schema:
                type: object
                properties:
                  StatusCode:
                    type: integer
                    example: 200
                  Response:
                    type: object
                    properties:
                      answer:
                        type: string
                        description: Generated answer based on retrieved documents
                        example: "محمد صلاح حامد محروس غالي"
                      chat_history:
                        type: array
                        description: Conversation history if applicable
                      retrieved_documents:
                        type: array
                        description: Documents used to generate the answer
                        items:
                          type: object
                          properties:
                            text:
                              type: string
                              description: Content of the retrieved document chunk
                            score:
                              type: number
                              description: Relevance score (0-1)
                            metadata:
                              type: object
                              description: Document metadata
                              properties:
                                file_id:
                                  type: string
                                  description: Source document identifier
                                Section Title:
                                  type: string
                                  description: Section within the document
                  Consumption:
                    type: string
                    description: Usage tracking
                    example: "3600/10000000"

  /api/v1/RAG/Stream/Answer:
    post:
      tags: ["RAG Answer Generation"]
      summary: Stream Answer
      description: |
        Streaming RAG answers for real-time response generation with document citations and progressive content delivery.
        
        **Key Features:**
        - Real-time answer streaming
        - Progressive document retrieval
        - Source citations in stream
        - Lower latency for long answers

        Note: Example requests/responses shown here are illustrative. When using the live "Try it" tool, you may see two responses: an HTTP status preview from the client and the API's streaming output.
      operationId: ragAnswerStreaming
      requestBody:
        required: true
        content:
          application/json:
            schema: 
              $ref: '#/components/schemas/RAGStreamRequest'
            examples:
              streamingQuery:
                summary: Streaming RAG query
                description: Complex question requiring streaming response
                value:
                  Question: "اشرح لي تاريخ الحضارة المصرية القديمة"
                  IndexNames: ["Ancient_Egypt", "Egyptian_History"]
                  Temperature: 0.3
                  MaxOutputTokens: 2048
                  IsStream: true
      responses:
        '200':
          description: Streaming RAG response with progressive content and citations
          content:
            text/event-stream:
              schema:
                type: string
                description: Server-sent events with answer chunks and metadata

  /api/AIKnowledge/upload-to-s3:
    get:
      tags: ["RAG Knowledge Indexing"]
      summary: Upload Knowledge Unit
      description: |
        Get an upload URL for sending the raw file of a knowledge unit. 
        After the upload succeeds, you must call "Add Knowledge" to register the uploaded file as a knowledge unit in your bot.
        
        **Process:**
        1. Call this endpoint to get an upload URL
        2. Upload your file using the provided URL
        3. Call "Add Knowledge" to register the uploaded file as a knowledge unit
        
        **Supported File Types:**
        - PDF documents
        - Microsoft Word (DOCX)
        - Plain text (TXT)
        - Rich text (RTF)
        - And other common document formats

        Note: Example requests/responses shown here are illustrative. When using the live "Try it" tool, you may see two responses: an HTTP status preview and the API's JSON body.
      operationId: getUploadUrl
      responses:
        '200':
          description: Upload URL for file
          content:
            application/json:
              schema:
                type: object
                properties:
                  StatusCode:
                    type: integer
                    example: 200
                  Response:
                    type: object
                    properties:
                      uploadUrl:
                        type: string
                        format: uri
                        description: Upload URL for file
                      fileKey:
                        type: string
                        description: File key identifier
                      expiresIn:
                        type: integer
                        description: URL expiration time in seconds
                  Consumption:
                    type: string
                    example: "0/10000000"

  /api/AIKnowledge/{botId}:
    post:
      tags: ["RAG Knowledge Indexing"]
      summary: Register Knowledge Unit
      description: |
        Register a new knowledge unit (file or URL) to your bot's knowledge base for indexing.
        
        **Supported Sources:**
        - **URLs (KnowledgeSource = 1)**: Web pages, documentation, articles
        - **Files (KnowledgeSource = 0)**: PDF, DOCX, TXT, and other document formats
        
        **Process:**
        1. For files: First upload using the upload URL endpoint
        2. Create a knowledge unit with file details or URL
        3. System automatically indexes the content
        4. Content becomes available for RAG queries

        Note: Example requests/responses shown here are illustrative. When using the live "Try it" tool, you may see two responses: an HTTP status preview and the API's JSON body.
      operationId: addKnowledge
      parameters:
        - in: path
          name: botId
          required: true
          schema:
            type: string
          description: Bot ID to add knowledge to
          example: "12345"
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/AIKnowledgeRequest'
            examples:
              urlSource:
                summary: URL-based knowledge
                description: Add knowledge from a web URL
                value:
                  title: "API Documentation"
                  description: "Wikipedia API documentation"
                  KnowledgeSource: 1
                  SourceContent: ["https://en.wikipedia.org/wiki/API"]
              fileSource:
                summary: File-based knowledge
